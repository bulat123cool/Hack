local function createButton(t)
	local button = Instance.new("TextButton")
	if t.Parent then
		button.Parent = t.Parent
	else
		button.Parent = scrollingFrame
	end
	if t.SetName then
		button.Name = t.SetName
	else
		button.Name = "a"
	end
	if t.Size then
		button.Size = t.Size
	else
		button.Size = UDim2.new(1, 0, 0, 32)
	end
	if t.BC3 then
		button.BackgroundColor3 = t.BC3
	else
		button.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	end
	if t.Text then
		button.Text = t.Text
	else
		button.Text = "button"..button.Name
	end
	if t.textcolor then
		button.TextColor3 = t.textcolor
	else
		button.TextColor3 = Color3.fromRGB(255, 255, 255)
	end
	if t.Transparency then
		button.BackgroundTransparency = t.Transparency
	else
		button.BackgroundTransparency = 0.8
	end
	button.TextScaled = true
	return button
end
