local function updateCanvasSize(reason)
	scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y)
	if reason then
		scrollingFrame.CanvasPosition = Vector2.new(0,layout.AbsoluteContentSize.Y)
	else
		scrollingFrame.CanvasPosition = Vector2.new(0,0)
	end
end
